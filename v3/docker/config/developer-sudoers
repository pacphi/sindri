# ============================================================================
# Sindri Sudoers Configuration - Development Environment
# ============================================================================
# Simplified configuration for development containers
#
# Security Note: This grants full sudo access without password for developer user
# - Acceptable for development environments where user already has root-equivalent access
# - NOT recommended for production without additional security controls
#
# Context: Restricted sudo (C-5) caused functional issues with apt-get via env wrapper
# Research showed standard practice for dev containers is NOPASSWD: ALL
#
# See Security Audit Report C-5 for full risk analysis and accepted risk justification
# Last Updated: December 17, 2025
# ============================================================================

# Ensure /usr/local/bin is in PATH for all distros (openSUSE excludes it by default)
Defaults secure_path="/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# Preserve mise and sindri environment variables through sudo
# Belt-and-suspenders: ensures critical vars survive even if --preserve-env parsing fails
# (e.g., openSUSE grep lacks PCRE support, breaking the entrypoint's env propagation)
Defaults env_keep += "SINDRI_DISTRO SINDRI_EXT_HOME SINDRI_SOURCE_REF MISE_DATA_DIR MISE_CONFIG_DIR MISE_CACHE_DIR MISE_STATE_DIR MISE_TRUSTED_CONFIG_PATHS MISE_YES TMPDIR"

# Allow developer user passwordless access to ALL commands
developer ALL=(ALL) NOPASSWD: ALL
