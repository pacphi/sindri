# Ruflo - AI Agent Orchestration Platform
# Successor to Claude Flow (v3.5 rebrand)
# All claude-flow commands work identically via ruflo
#
# Features:
# - 18 modular packages
# - UnifiedSwarmCoordinator
# - Flash Attention + SONA neural learning
# - HNSW vector search (150x-12,500x faster)
# - 17 lifecycle hooks + 12 background workers
# - Plugin SDK for extensibility
# - 215 MCP tools

# === CORE OPERATIONS ===
alias rf-init="ruflo init --start-all --topology hierarchical-mesh"
alias rf-init-minimal="ruflo init --force"
alias rf-doctor="ruflo doctor --fix"
alias rf-version="ruflo --version"
alias rf-help="ruflo --help"
alias rf-status="ruflo status"

# === SWARM COORDINATION ===
alias rf-swarm="ruflo swarm init --topology hierarchical-mesh"
alias rf-swarm-status="ruflo swarm status --watch"
alias rf-swarm-spawn="ruflo swarm spawn --agents 15"
alias rf-swarm-parallel="ruflo swarm execute --parallel"

# === AGENT MANAGEMENT ===
alias rf-agent="ruflo agent spawn"
alias rf-agent-list="ruflo agent list"
alias rf-agent-status="ruflo agent status"

# === MEMORY OPERATIONS (HNSW-indexed) ===
alias rf-memory="ruflo memory search"
alias rf-memory-store="ruflo memory store"
alias rf-memory-stats="ruflo memory stats"
alias rf-memory-clear="ruflo memory clear"

# === HOOKS SYSTEM ===
alias rf-hooks="ruflo hooks list"
alias rf-hooks-session="ruflo hooks session-start"
alias rf-hooks-worker="ruflo hooks worker list"
alias rf-hooks-dispatch="ruflo hooks worker dispatch"

# === PERFORMANCE & BENCHMARKING ===
alias rf-benchmark="ruflo performance benchmark --suite all"
alias rf-profile="ruflo performance profile"
alias rf-optimize="ruflo performance optimize"

# === SECURITY SCANNING ===
alias rf-security="ruflo security scan --depth full"
alias rf-cve="ruflo security cve --fix"
alias rf-audit="ruflo security audit"

# === MCP TOOLS (215 tools) ===
alias rf-mcp="ruflo mcp tools"
alias rf-mcp-start="ruflo mcp start"

# === NEURAL INTELLIGENCE (SONA) ===
alias rf-neural="ruflo neural status"
alias rf-learn="ruflo neural train"

# === QUICK SHORTCUTS ===
alias rfs="ruflo status"
alias rfh="ruflo --help"
alias rfd="ruflo doctor --fix"
alias rfb="ruflo performance benchmark"
alias rfm="ruflo memory search"
alias rfhooks="ruflo hooks list"
