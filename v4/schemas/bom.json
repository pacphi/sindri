{
  "$defs": {
    "BomEntry": {
      "description": "An entry in the BOM manifest referencing a component",
      "properties": {
        "address": {
          "description": "`backend:name[@qualifier]` address (ADR-004).",
          "type": "string"
        },
        "options": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "version": {
          "anyOf": [
            {
              "$ref": "#/$defs/VersionSpec"
            },
            {
              "type": "null"
            }
          ],
          "description": "Pinned version or version range (resolved to exact in `sindri.lock`)."
        }
      },
      "required": [
        "address"
      ],
      "type": "object"
    },
    "OverrideEntry": {
      "properties": {
        "address": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "address",
        "reason"
      ],
      "type": "object"
    },
    "Preferences": {
      "properties": {
        "backend_order": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": [
            "object",
            "null"
          ]
        },
        "default_target": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "RegistryConfig": {
      "properties": {
        "name": {
          "type": "string"
        },
        "trust": {
          "anyOf": [
            {
              "$ref": "#/$defs/TrustConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "url"
      ],
      "type": "object"
    },
    "TargetConfig": {
      "properties": {
        "auth": {
          "additionalProperties": {
            "type": "string"
          },
          "type": [
            "object",
            "null"
          ]
        },
        "infra": true,
        "kind": {
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "TrustConfig": {
      "properties": {
        "signer": {
          "type": "string"
        }
      },
      "required": [
        "signer"
      ],
      "type": "object"
    },
    "VersionSpec": {
      "oneOf": [
        {
          "enum": [
            "latest"
          ],
          "type": "string"
        },
        {
          "additionalProperties": false,
          "properties": {
            "exact": {
              "type": "string"
            }
          },
          "required": [
            "exact"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "range": {
              "type": "string"
            }
          },
          "required": [
            "range"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://schemas.sindri.dev/v4/bom.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "sindri v4 bom schema",
  "properties": {
    "$schema": {
      "type": [
        "string",
        "null"
      ]
    },
    "components": {
      "items": {
        "$ref": "#/$defs/BomEntry"
      },
      "type": "array"
    },
    "name": {
      "type": [
        "string",
        "null"
      ]
    },
    "override": {
      "items": {
        "$ref": "#/$defs/OverrideEntry"
      },
      "type": [
        "array",
        "null"
      ]
    },
    "preferences": {
      "anyOf": [
        {
          "$ref": "#/$defs/Preferences"
        },
        {
          "type": "null"
        }
      ]
    },
    "registries": {
      "default": [],
      "items": {
        "$ref": "#/$defs/RegistryConfig"
      },
      "type": "array"
    },
    "secrets": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Optional secret references (Sprint 12, Wave 4C).\n\nMap of secret-id → prefixed `AuthValue` string (`env:FOO`,\n`file:~/.token`, `cli:gh`, `plain:…`). Resolved on demand by\n`sindri secrets validate`; values are never persisted.",
      "type": "object"
    },
    "targets": {
      "additionalProperties": {
        "$ref": "#/$defs/TargetConfig"
      },
      "default": {},
      "type": "object"
    }
  },
  "required": [
    "components"
  ],
  "title": "BomManifest",
  "type": "object"
}
