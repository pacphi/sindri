{
  "$defs": {
    "ComponentEntry": {
      "properties": {
        "backend": {
          "type": "string"
        },
        "depends_on": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "description": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ComponentKind"
        },
        "latest": {
          "type": "string"
        },
        "license": {
          "default": "",
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "oci_ref": {
          "type": "string"
        },
        "versions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "name",
        "backend",
        "latest",
        "description",
        "kind",
        "oci_ref"
